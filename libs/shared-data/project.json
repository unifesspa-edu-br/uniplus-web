{
  "name": "shared-data",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/shared-data/src",
  "prefix": "data",
  "projectType": "library",
  "tags": ["scope:shared", "type:data"],
  "targets": {
    "build": {
      "executor": "@nx/angular:ng-packagr-lite",
      "outputs": ["{workspaceRoot}/dist/{projectRoot}"],
      "options": {
        "project": "libs/shared-data/ng-package.json",
        "tsConfig": "libs/shared-data/tsconfig.lib.json"
      },
      "configurations": {
        "production": {
          "tsConfig": "libs/shared-data/tsconfig.lib.prod.json"
        },
        "development": {}
      },
      "defaultConfiguration": "production"
    },
    "lint": {
      "executor": "@nx/eslint:lint"
    },
    "codegen-api": {
      "executor": "nx:run-commands",
      "options": {
        "command": "bash libs/shared-data/scripts/generate-api-clients.sh",
        "cwd": "{workspaceRoot}"
      },
      "inputs": [
        "{projectRoot}/openapi/selecao.openapi.json",
        "{projectRoot}/openapi/ingresso.openapi.json",
        "{projectRoot}/scripts/generate-api-clients.sh"
      ],
      "outputs": [
        "{projectRoot}/src/lib/api/selecao/schema.ts",
        "{projectRoot}/src/lib/api/ingresso/schema.ts"
      ]
    },
    "codegen-api-check": {
      "executor": "nx:run-commands",
      "options": {
        "command": "bash libs/shared-data/scripts/verify-codegen.sh",
        "cwd": "{workspaceRoot}"
      }
    }
  }
}
